# --- Database (libSQL / Turso) ---
# Local development: a plain SQLite file (NOT committed, NOT used on Vercel).
DATABASE_URL="file:./local.db"

# Production (Vercel): point at your Turso database.
# DATABASE_URL="libsql://<your-db>-<org>.turso.io"
# DATABASE_AUTH_TOKEN="<your-turso-auth-token>"
DATABASE_AUTH_TOKEN=""

# --- Edit login ---
# Credentials live here in the environment only (not in the database). Login
# compares against these; AUTH_SECRET signs the session cookie. Set all three
# as environment variables in production (Vercel) too. Keep AUTH_SECRET secret
# and stable — changing it logs everyone out.
APP_USERNAME="admin"
APP_PASSWORD="change-me"
AUTH_SECRET="generate-a-long-random-string"
